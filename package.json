{
  "name": "bitspv-pay",
  "private": true,
  "version": "1.6.0",
  "packageManager": "pnpm@10.6.4",
  "type": "module",
  "scripts": {
    "start": "npm run dev",
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "format": "prettier --write \"src/**/*.{js,jsx,ts,tsx,css,scss,less,json,md}\"",
    "ship": "URL=$(vercel 2>&1 | grep -o 'https://[^ ]*\\.vercel\\.app' | tail -1) && ./scripts/notify.sh \"🚀 Preview: $URL\"",
    "ship:prod": "vercel --prod",
    "build:offline": "vite build --config vite.config.offline.ts && node scripts/release-offline.mjs"
  },
  "dependencies": {
    "@bsv/paymail": "^2.1.1",
    "@bsv/sdk": "^1.8.13",
    "@radix-ui/react-alert-dialog": "^1.1.15",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-slot": "^1.2.4",
    "buffer": "^6.0.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "i18next": "^25.7.4",
    "i18next-browser-languagedetector": "^8.2.0",
    "jsqr": "^1.4.0",
    "lucide-react": "^0.562.0",
    "pako": "^2.1.0",
    "qrcode": "^1.5.4",
    "react": "^19.2.3",
    "react-dom": "^19.2.3",
    "react-ga4": "^2.1.0",
    "react-hook-form": "^7.71.1",
    "react-i18next": "^16.5.2",
    "react-router-dom": "^7.12.0",
    "tailwind-merge": "^3.4.0",
    "tailwindcss-animate": "^1.0.7"
  },
  "devDependencies": {
    "@types/react": "^19.2.8",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.2",
    "autoprefixer": "^10.4.17",
    "eslint-plugin-prettier": "^5.2.1",
    "postcss": "^8.4.33",
    "prettier": "^3.3.3",
    "tailwindcss": "^3.4.1",
    "typescript": "^5.0.2",
    "vite": "^7.3.1",
    "vite-plugin-html": "^3.2.2",
    "vite-plugin-pwa": "^1.2.0",
    "vite-plugin-singlefile": "^2.3.3"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "unrs-resolver"
    ]
  }
}
